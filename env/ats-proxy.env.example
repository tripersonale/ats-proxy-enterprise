# ATS Proxy Enterprise - environment template
#
# Usage:
#   cp env/ats-proxy.env.example ats-proxy.env
#   edit ats-proxy.env
#   sudo bash scripts/install-ats-proxy.sh --env ats-proxy.env --non-interactive
#
# Do not commit the copied ats-proxy.env file.

# Host and network
ATS_HOSTNAME=ats-proxy-01
ATS_IP_CIDR=192.168.89.100/24
ATS_GATEWAY=192.168.89.254
ATS_DNS=1.1.1.1

# Client subnet allowed to reach the proxy port
ATS_ALLOWED_SUBNET=192.168.89.0/24

# Admin client IPs bypass all plugin rules. Comma-separated.
ATS_ADMIN_IPS=192.168.89.10

# URL filtering. Comma-separated. Regex patterns are supported by the plugin.
ATS_DENY_DOMAINS=httpbin.org,bad.com,malware.net,.*\.ru$
ATS_WHITELIST_DOMAINS=google.com,github.com,ubuntu.com,example.com

# Proxy users in user:password form, comma-separated.
# Replace every CHANGE_ME value before running the installer.
ATS_AUTH_USERS=admin:CHANGE_ME,user1:CHANGE_ME

# Optional static routes in net:gw form, comma-separated. Leave empty if unused.
ATS_STATIC_ROUTES=

# Service options
ATS_PROXY_PORT=8080
ATS_APPLY_NETPLAN=n
ATS_TLS_ENABLED=n

# Plugin binary path. The recovered v2.1 binary is versioned in bin/.
ATS_PLUGIN_PATH=./bin/ats_proxy_filter_v21.so
