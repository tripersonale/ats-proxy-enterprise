# Proxmox environment template
#
# Usage with CULLA deploy scripts:
#   cp env/proxmox.env.example ~/CULLA-instance/.env
#   edit ~/CULLA-instance/.env
#
# Keep real values only in the private CULLA-instance .env file.

PROXMOX_HOST=CHANGE_ME
PROXMOX_USER=root@pam
PROXMOX_PASS=CHANGE_ME
PROXMOX_NODE=CHANGE_ME
PROXMOX_STORAGE_DISK=CHANGE_ME
PROXMOX_STORAGE_ISO=local

# Persistent SSH key directory for generated VM access keys.
SSH_KEY_DIR=$HOME/CULLA-instance/01_SECRETS/ssh

# Optional VM defaults for repeatable lab deployments.
ATS_VMID=CHANGE_ME
ATS_VM_NAME=ats-proxy-01
ATS_VM_IP=CHANGE_ME
ATS_VM_GW=192.168.89.254
ATS_VM_DNS=1.1.1.1
ATS_VM_USER=ubuntu
