# ATS Proxy Enterprise — Config file template
# Rinomina in ats-proxy.conf e compila, poi esegui:
#   ./install-ats-proxy.sh --config ats-proxy.conf
# Oppure lascia vuoto per la modalità interattiva.

# Network
HOSTNAME=ats-proxy-01
IP=192.168.89.100/24
GATEWAY=192.168.89.254
DNS=1.1.1.1

# Subnet autorizzata ad usare il proxy
ALLOWED_SUBNET=192.168.89.0/24

# IP Admin (bypassano tutte le regole) — separati da virgola
ADMIN_IPS=192.168.89.10,192.168.89.11

# Domini BLOCCATI — separati da virgola. Supporta regex con .*
DENY_DOMAINS=httpbin.org,bad.com,malware.net,.*\.ru$

# Domini WHITELIST — accesso libero senza autenticazione
WHITELIST_DOMAINS=google.com,github.com,ubuntu.com,example.com

# Utenti per autenticazione proxy (user:password) — separati da virgola
AUTH_USERS=admin:proxy2026,user1:pass123,operator:op3rat0r

# Rotte statiche (net/gw) — separati da virgola. Lascia vuoto se non servono
STATIC_ROUTES=

# Porta proxy
PROXY_PORT=8080

# Abilitare TLS su porta 8443? (y/n)
TLS_ENABLED=n
